# ─── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── AI Services ─────────────────────────────────────────────────────────────
# Dream Parser (server-side only — never expose in client)
OPENAI_API_KEY=sk-...

# Generative Video (Runway ML)
RUNWAY_API_KEY=...
RUNWAY_API_SECRET=...

# Text-to-Speech / Audio Soundscape (ElevenLabs)
ELEVENLABS_API_KEY=...

# Whisper / Speech-to-Text (via OpenAI or local Whisper endpoint)
WHISPER_ENDPOINT=https://api.openai.com/v1/audio/transcriptions

# ─── Stripe ──────────────────────────────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (from Stripe dashboard)
STRIPE_PRICE_LUCID_MONTHLY=price_...
STRIPE_PRICE_LUCID_ANNUAL=price_...
STRIPE_PRICE_ORACLE_MONTHLY=price_...
STRIPE_PRICE_ORACLE_ANNUAL=price_...

# ─── Push Notifications ───────────────────────────────────────────────────────
EXPO_PUBLIC_PUSH_TOKEN_ENDPOINT=https://your-project.supabase.co/functions/v1/push

# ─── App Config ──────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development   # development | staging | production
EXPO_PUBLIC_FREE_TIER_LIMIT=3     # dreams/month for free tier
