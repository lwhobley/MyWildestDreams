{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*":            ["./*"],
      "@/src/*":        ["./src/*"],
      "@/components/*": ["./components/*"],
      "@/constants/*":  ["./constants/*"],
      "@/contexts/*":   ["./contexts/*"],
      "@/hooks/*":      ["./hooks/*"],
      "@/services/*":   ["./services/*"],
      "@/utils/*":      ["./utils/*"],
      "@/lib/*":        ["./src/lib/*"],
      "@/stores/*":     ["./src/stores/*"],
      "@/stores":       ["./src/stores/index"],
      "@/types":        ["./src/types/index"],
      "@/types/*":      ["./src/types/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "expo-env.d.ts"]
}
